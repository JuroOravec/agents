{
  "name": "agents",
  "version": "0.0.0",
  "description": "AI agents and crews (Mastra, scripts, skills)",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "knip": "knip --exclude types",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "tsx src/commands/cli.ts preview",
    "validate": "tsx src/commands/cli.ts validate",
    "check": "tsx src/commands/cli.ts check",
    "check:agent": "tsx src/commands/cli.ts check --reporter=agent"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JuroOravec/agents.git"
  },
  "bugs": {
    "url": "https://github.com/JuroOravec/agents/issues"
  },
  "homepage": "https://github.com/JuroOravec/agents",
  "dependencies": {
    "@ai-sdk/openai": "^3.0.34",
    "@ai-sdk/provider": "^1.0.0",
    "@clack/prompts": "^1.0.1",
    "@mastra/core": "latest",
    "chalk": "^5.6.2",
    "marked": "15",
    "marked-terminal": "^7.3.0",
    "zod": "^3"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/express": "^4",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "express": "^4",
    "knip": "^5.85.0",
    "prettier": "^3",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^2"
  }
}